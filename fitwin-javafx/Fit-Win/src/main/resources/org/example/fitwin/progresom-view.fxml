<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.fitwin.ProgresoMController"
      prefHeight="640" prefWidth="360"
      spacing="16" stylesheets="@estilos.css"
      styleClass="fondo-oscuro">

    <HBox alignment="TOP_LEFT" spacing="12">

        <Button fx:id="VolverBtn" onAction="#onBackToProgresoClick" styleClass="volver-btn"/>
        <MenuButton fx:id="metricMenu" text="Brazo (cm)" styleClass="objetivo-card">
            <items>
                <MenuItem text="Brazo (cm)"   onAction="#onMetricBrazo"/>
                <MenuItem text="Pecho (cm)"   onAction="#onMetricPecho"/>
                <MenuItem text="Espalda (cm)" onAction="#onMetricEspalda"/>
                <MenuItem text="Hombro (cm)"  onAction="#onMetricHombro"/>
                <MenuItem text="Muslo (cm)"   onAction="#onMetricMuslo"/>
            </items>
        </MenuButton>
    </HBox>

    <HBox alignment="CENTER" spacing="12">
        <VBox alignment="CENTER">
            <Label text="Desde" styleClass="etiqueta-progreso"/>
            <DatePicker fx:id="desdePicker" showWeekNumbers="false" />
        </VBox>
        <VBox alignment="CENTER">
            <Label text="Hasta" styleClass="etiqueta-progreso"/>
            <DatePicker fx:id="hastaPicker" showWeekNumbers="false" />
        </VBox>
    </HBox>

    <StackPane styleClass="progreso-chart-card">
        <LineChart fx:id="lineChart" animated="false" legendVisible="false" prefHeight="360" styleClass="progreso-linechart">
            <xAxis><CategoryAxis fx:id="xAxis" styleClass="progreso-xaxis"/></xAxis>
            <yAxis><NumberAxis fx:id="yAxis"  styleClass="progreso-yaxis"/></yAxis>
        </LineChart>
    </StackPane>

    <HBox alignment="CENTER" spacing="20">
    <Button text=" " onAction="#onCalcularClick" styleClass="btn-actualizar"/>
    </HBox>

    <HBox alignment="CENTER">
    <Label fx:id="resumenLbl" text="" styleClass="progreso-mensaje"/>
    </HBox>

    <Pane VBox.vgrow="ALWAYS"/>
</VBox>
