<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER"
      spacing="20"
      prefHeight="640" prefWidth="360"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.fitwin.GuiaController"
      stylesheets="@estilos.css"
      styleClass="fondo-oscuro">

    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="VolverBtn" onAction="#onBackToEjercicioClick" styleClass="volver-btn" prefWidth="50" prefHeight="50"/>
    </HBox>

    <VBox>
        <TextField fx:id="BuscarTxt" promptText="Buscar ejercicio" prefWidth="240" prefHeight="40" styleClass="fitwin-txt"/>
    </VBox>

    <VBox prefHeight="20" opacity="0"/>

    <ScrollPane fx:id="GuiaScroll" prefWidth="340" prefHeight="480" fitToWidth="true" fitToHeight="true" styleClass="scroll-transparente">
        <VBox fx:id="ContenedorImg" spacing="10"/>
    </ScrollPane>
</VBox>