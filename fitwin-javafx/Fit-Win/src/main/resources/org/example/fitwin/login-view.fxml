<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER"
      prefHeight="600" prefWidth="360" spacing="16"
      stylesheets="@estilos.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.fitwin.LoginController"
      styleClass="fondo-oscuro">


<VBox alignment="CENTER">

  <ImageView fitHeight="400" fitWidth="400" preserveRatio="true">
    <image>
      <Image url="@iconos/Logo2.0.png" />
    </image>
  </ImageView>

    <Label fx:id="FitWinEtiq"  text="Control total de la experiencia"  />
</VBox>


<VBox alignment="CENTER" spacing="8" >
  <TextField fx:id="EmailTxt" promptText="EMAIL" styleClass="fitwin-txt" />
  <PasswordField fx:id="PassTxt" promptText="CONTRASEÑA"  styleClass="fitwin-txt"  />
</VBox>

  <Label fx:id="EstadoLbl" text="" visible="false" managed="false" styleClass="alerta-texto" />

  <HBox alignment="CENTER" spacing="12">
    <Button fx:id="RegisterBtn" onAction="#onRegisterButtonClick" text="CREAR CUENTA" styleClass="sesion-btn"/>
    <Button fx:id="LoginBtn" onAction="#onLoginButtonClick"  text="INICIAR SESION" styleClass="sesion-btn"/>
  </HBox>
</VBox>
