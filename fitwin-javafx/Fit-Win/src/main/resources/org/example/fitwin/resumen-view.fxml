<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" prefHeight="640" prefWidth="360"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.fitwin.ResumenController"
      stylesheets="@estilos.css" styleClass="fondo-oscuro">

    <HBox spacing="20">
        <padding>
            <Insets top="10" left="10"/>
        </padding>
        <Button fx:id="VolverBtn" onAction="#onBackToComidaClick" styleClass="volver-btn"/>
    </HBox>

    <VBox alignment="CENTER" spacing="30">
        <padding>
            <Insets top="40" bottom="20"/>
        </padding>

        <VBox alignment="CENTER" spacing="10" fx:id="CajaCalorias" prefWidth="250" prefHeight="150">
            <Label text="Calorías Consumidas" fx:id="CaloriasTitulo" />
            <Label fx:id="CaloriasEtiq" text="0kcal" styleClass="calorias-valor" maxWidth="Infinity" />
        </VBox>

        <HBox alignment="CENTER" spacing="20">
            <VBox fx:id="CajaProte" alignment="CENTER" >
                <Label fx:id="ProteinasEtiq" text="0g" styleClass="macro-num" />
                <Label text="Proteína" styleClass="macro-titulo" />
            </VBox>
            <VBox fx:id="CajaCarbs" alignment="CENTER" >
                <Label fx:id="CarbohidratosEtiq" text="0g" styleClass="macro-num" />
                <Label text="Carbohidratos" styleClass="macro-titulo" />
            </VBox>
            <VBox fx:id="CajaGrasa" alignment="CENTER" >
                <Label fx:id="GrasasEtiq" text="0g" styleClass="macro-num" />
                <Label text="Grasas" styleClass="macro-titulo" />
            </VBox>
        </HBox>

        <VBox fx:id="CajaAgua" alignment="CENTER" spacing="5">
            <Label fx:id="AguaEtiq" text="0L agua = 0 vasos" styleClass="agua-texto" />
            <Slider fx:id="BarraAgua" prefWidth="250" min="0" max="2" blockIncrement="0.25"
                    majorTickUnit="0.25" minorTickCount="0" showTickMarks="true" snapToTicks="true"/>
        </VBox>
    </VBox>

</VBox>