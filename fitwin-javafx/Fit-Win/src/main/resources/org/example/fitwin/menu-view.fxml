<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER"
      spacing="20"
      prefHeight="640" prefWidth="360"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.fitwin.MenuController"
      stylesheets="@estilos.css"
      styleClass="fondo-oscuro">

    <VBox fx:id="ZonaPrincipal" alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER" spacing="20">
            <Button fx:id="ComidaBtn" onAction="#alHacerClickEnComidas" styleClass="btn-negro"/>
            <Button fx:id="PerfilBtn" onAction="#alHacerClickEnBotonPerfil" styleClass="btn-amarillo"/>
        </HBox>

        <HBox alignment="CENTER" spacing="20">
            <Button fx:id="AjustesBtn" onAction="#alHacerClickEnBotonAjustes" styleClass="btn-amarillo"/>
            <Button fx:id="EjercicioBtn" onAction="#alHacerClickEnBotonEjercicio" styleClass="btn-negro"/>
        </HBox>

        <HBox alignment="CENTER" spacing="10">
            <Button fx:id="TrackerBtn"  onAction="#alHacerClickEnBotonTracker" styleClass="btn-negro"/>
            <Button fx:id="CerrarSesionBtn" onAction="#alHacerClickEnBotonCerrarSesion" styleClass="btn-amarillo"/>
        </HBox>
    </VBox>


    <VBox fx:id="CajaInferior" alignment="CENTER" spacing="16" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER" spacing="60">
            <Button fx:id="PesoBtn"     text="PESAJE"   onAction="#alHacerClickEnBotonPeso"/>
            <Button fx:id="MedidasBtn"  text="MEDIDAS"  onAction="#alHacerClickEnBotonMedidas"/>
        </HBox>

        <HBox alignment="CENTER">
            <Button fx:id="ObjetivosBtn" text="OBJETIVOS" onAction="#alHacerClickEnBotonObjetivos"/>
        </HBox>
    </VBox>
</VBox>
