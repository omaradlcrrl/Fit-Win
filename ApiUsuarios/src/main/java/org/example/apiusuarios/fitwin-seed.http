# ─────────────────────────────────────────────────────────────────────────────
# PASO 10 — Medición corporal
# ─────────────────────────────────────────────────────────────────────────────

### 10. Registrar medición corporal completa
POST {{base}}/mediciones/save
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "usuarioId": {{usuarioId}},
  "peso": 80.0,
  "porcentajeGrasa": 16.5,
  "masaMagra": 66.8,
  "cintura": 82.0,
  "pecho": 102.0,
  "brazo": 37.0,
  "muslo": 58.0,
  "hombro": 116.0,
  "espalda": 109.0
}

# ─────────────────────────────────────────────────────────────────────────────
# PASO 11 — Foto de progreso
# ─────────────────────────────────────────────────────────────────────────────

### 11a. Foto frontal
POST {{base}}/fotos-progreso/save
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "usuarioId": {{usuarioId}},
  "urlFoto": "https://cdn.fitwin.app/fotos/omar/2025-04-17-frontal.jpg",
  "tipoFoto": "FRONTAL"
}

### 11b. Foto espalda
POST {{base}}/fotos-progreso/save
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "usuarioId": {{usuarioId}},
  "urlFoto": "https://cdn.fitwin.app/fotos/omar/2025-04-17-espalda.jpg",
  "tipoFoto": "ESPALDA"
}

# ─────────────────────────────────────────────────────────────────────────────
# PASO 12 — Generar objetivo nutricional
# ─────────────────────────────────────────────────────────────────────────────

### 12. Generar objetivo calórico automático (TDEE + ajuste SUPERAVIT 15%)
POST {{base}}/objetivos/generar/{{usuarioId}}
Authorization: Bearer {{token}}

# ─────────────────────────────────────────────────────────────────────────────
# VERIFICACIÓN — Leer todo lo creado
# ─────────────────────────────────────────────────────────────────────────────

### Ver perfil completo
GET {{base}}/usuarios/{{usuarioId}}
Authorization: Bearer {{token}}

### Ver objetivo del día
GET {{base}}/objetivos/actual/{{usuarioId}}
Authorization: Bearer {{token}}

### Ver comidas de hoy
GET {{base}}/comidas/hoy/{{usuarioId}}
Authorization: Bearer {{token}}

### Ver historial de sesiones
GET {{base}}/sesiones?usuarioId={{usuarioId}}
Authorization: Bearer {{token}}

### Ver series de la sesión 1
GET {{base}}/series?sesionId=1
Authorization: Bearer {{token}}

### Ver records del usuario (deberían aparecer auto-generados)
GET {{base}}/records?usuarioId={{usuarioId}}
Authorization: Bearer {{token}}

### Ver mejor record de press banca (ejercicioGlobalId=1)
GET {{base}}/records/ejercicio/max?usuarioId={{usuarioId}}&ejercicioGlobalId=1
Authorization: Bearer {{token}}

### Ver historial de records de press banca
GET {{base}}/records/ejercicio?usuarioId={{usuarioId}}&ejercicioGlobalId=1
Authorization: Bearer {{token}}

### Ver última medición corporal
GET {{base}}/mediciones/ultima/{{usuarioId}}
Authorization: Bearer {{token}}

### Ver fotos de progreso
GET {{base}}/fotos-progreso?usuarioId={{usuarioId}}
Authorization: Bearer {{token}}

### Ver ejercicios de la rutina
GET {{base}}/ejercicios?rutinaId=1
Authorization: Bearer {{token}}

### Ver catálogo completo de ejercicios
GET {{base}}/ejercicios-globales
Authorization: Bearer {{token}}
